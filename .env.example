# Đổi tên file này thành .env và điền thông tin thật của bạn

# Đổi tên file này thành .env và điền thông tin thật của bạn

# --- Cấu hình cho PostgreSQL local ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vn_review_sentiment
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_SSLMODE=disable

# --- Cấu hình cho Aiven Cloud PostgreSQL ---
# Lấy các giá trị này trong Aiven Console > Service > Overview > Connection Information
DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password_here
# Aiven bắt buộc SSL. 'require' là đủ dùng cho pet project (không cần verify-ca/verify-full)
DB_SSLMODE=require
# Chỉ cần điền nếu bạn dùng sslmode=verify-ca hoặc verify-full
# (tải file ca.pem từ Aiven Console > Overview > CA Certificate)
DB_SSLROOTCERT=

# Số giây nghỉ giữa các request khi crawl (tránh spam server)
CRAWL_DELAY_SECONDS=1.0

# Đường dẫn lưu model đã train
MODEL_DIR=./models_artifacts

